{
  "name": "gamemirror-monorepo",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "dev:mobile": "expo start",
    "dev:backend": "npm --prefix backend run dev",
    "dev:host-agent": "npm --prefix host-agent run dev",
    "typecheck:mobile": "npm run typecheck",
    "typecheck:backend": "npm --prefix backend run typecheck",
    "typecheck:host-agent": "npm --prefix host-agent run typecheck",
    "typecheck:all": "npm run typecheck:mobile && npm run typecheck:backend && npm run typecheck:host-agent",
    "start:clear": "expo start -c",
    "prebuild:android": "expo prebuild -p android",
    "eas:build:dev": "eas build --platform android --profile development",
    "eas:build:preview": "eas build --platform android --profile preview",
    "eas:build:prod": "eas build --platform android --profile production"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.4",
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@tanstack/react-query": "^5.66.4",
    "expo": "~52.0.35",
    "expo-constants": "~17.0.7",
    "expo-linear-gradient": "~14.0.2",
    "expo-router": "~4.0.17",
    "expo-status-bar": "~2.0.1",
    "react": "18.3.1",
    "react-native": "0.76.7",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "~18.3.12",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^9.19.0",
    "eslint-config-universe": "^13.1.0",
    "typescript": "~5.7.3",
    "eas-cli": "^13.0.0"
  }
}